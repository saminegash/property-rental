# =============================================================================
# MyEthioProperties — Production Environment Variables Template
# =============================================================================
# Copy this file to .env.local (for local development) or configure these keys
# in your hosting provider's dashboard (e.g. Vercel, Netlify).
# DO NOT commit .env.local to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Client-safe variables (bundled into the browser)
# These are prefixed with NEXT_PUBLIC_ and visible to anyone.
# ---------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---------------------------------------------------------------------------
# Server-only variables (NEVER exposed to the browser)
# These must NOT be prefixed with NEXT_PUBLIC_.
# ---------------------------------------------------------------------------

# Supabase Service Role Key (Used for admin actions bypassing RLS)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Secret salt used to hash viewer IPs/User-Agents uniquely for analytics
# MANDATORY in production. If missing, analytics tracking is skipped.
ANALYTICS_SALT=your-long-secure-random-analytics-salt

# Resend API Key for sending system emails without external npm dependencies
RESEND_API_KEY=re_your_resend_api_key

# Destination for administrator alerts when property or car inquiries are made
ADMIN_NOTIFICATION_EMAIL=admin@myethioproperties.com

# Destination phone number for administrator SMS alerts (optional / placeholder)
ADMIN_NOTIFICATION_PHONE=+251911123456
