# =============================================================================
# Car Rental Marketplace — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# DO NOT commit .env.local to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Client-safe variables (bundled into the browser)
# These are prefixed with NEXT_PUBLIC_ and visible to anyone.
# ---------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# Server-only variables (NEVER exposed to the browser)
# These must NOT be prefixed with NEXT_PUBLIC_.
# ---------------------------------------------------------------------------

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
